// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          String    @default("USER") // USER, SUPER_ADMIN
  planName      String    @default("Launch")
  monthlySpend  Int       @default(990)
  activeSwarms  Int       @default(2)
  processAccess Boolean   @default(true)
  organizationRole String @default("OWNER") // OWNER, ADMIN, MEMBER, VIEWER
  organizationId String?
  accounts      Account[]
  sessions      Session[]
  organization  Organization? @relation("OrganizationMembers", fields: [organizationId], references: [id], onDelete: SetNull)
  createdOrganizations Organization[] @relation("OrganizationCreators")
  ownedAgents   SwarmAgent[] @relation("AgentOwner")
  createdFeedback FeedbackEntry[] @relation("FeedbackCreator")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Organization {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  vision      String?
  mission     String?
  brandColor  String   @default("#5663e8")
  logoUrl     String?
  createdById String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  createdBy User?  @relation("OrganizationCreators", fields: [createdById], references: [id], onDelete: SetNull)
  members   User[] @relation("OrganizationMembers")
  agents    SwarmAgent[] @relation("OrganizationAgents")
}

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id           String     @id @default(uuid())
  firstName    String?
  lastName     String?
  fullName     String
  email        String?
  institution  String?
  role         String?
  department   String?
  labName      String?
  
  sourceType   String     @default("AUTO") // AUTO, MANUAL
  sourceName   String?
  sourceUrl    String?
  eventName    String?

  status       String     @default("NEW") // NEW, REVIEW, APPROVED, REJECTED, CONTACTED, REPLIED, INTERESTED, CLOSED
  tier         String     @default("UNRANKED") // TIER1, TIER2, TIER3, UNRANKED
  fitScore     Int?
  intentScore  Int        @default(0)
  icpScore     Int        @default(0)
  priorityScore Int       @default(0)
  scoreUpdatedAt DateTime?
  researchArea String?
  notes        String?
  whyRelevant  String?
  aiSummary    String?
  rawSourceText String?
  conversationSummary String?
  assignedAgentId String?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignedAgent    SwarmAgent? @relation(fields: [assignedAgentId], references: [id], onDelete: SetNull)
  tags             LeadTag[]
  scoreBreakdowns  LeadScoreBreakdown[]
  signals          LeadSignal[]
  outreachDrafts   OutreachDraft[]
  inboxThreads     InboxThread[]
  attributions     RevenueAttribution[]
  feedbackEntries  FeedbackEntry[]
  activities       ActivityLog[]
}

model LeadTag {
  id     String @id @default(uuid())
  leadId String
  value  String

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadScoreBreakdown {
  id        String @id @default(uuid())
  leadId    String
  criterion String
  score     Int
  reason    String

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model OutreachDraft {
  id        String      @id @default(uuid())
  leadId    String
  subject   String
  body      String
  followup1 String?
  followup2 String?
  status    String      @default("PENDING_REVIEW") // PENDING_REVIEW, APPROVED, SENT, REJECTED, ARCHIVED
  aiModel   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
  feedbackEntries FeedbackEntry[]
}

model SwarmAgent {
  id                 String    @id @default(uuid())
  name               String
  goal               String
  budget             Int       @default(0)
  spend              Int       @default(0)
  revenue            Int       @default(0)
  strategy           String
  state              String    @default("DEPLOY") // DEPLOY, HUNT, CLOSE, KILL, PAUSED
  memorySummary      String?
  lastImprovementNote String?
  ownerId            String?
  organizationId     String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  owner         User? @relation("AgentOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  organization  Organization? @relation("OrganizationAgents", fields: [organizationId], references: [id], onDelete: SetNull)
  leads         Lead[]
  memoryEntries AgentMemoryEntry[]
  inboxThreads  InboxThread[]
  attributions  RevenueAttribution[]
  feedbackEntries FeedbackEntry[]
}

model AgentMemoryEntry {
  id          String   @id @default(uuid())
  agentId     String
  memoryType  String   // SUCCESS, FAILURE, PLAYBOOK, OBJECTION, CONTEXT
  title       String
  content     String
  campaignKey String?
  impactScore Int      @default(50)
  createdAt   DateTime @default(now())

  agent SwarmAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
}

model LeadSignal {
  id         String   @id @default(uuid())
  leadId      String
  signalType  String   // FIT, INTENT, ICP, TIMING, REPLY
  label       String
  source      String?
  score       Int
  metadata    String?
  createdAt   DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model InboxThread {
  id             String   @id @default(uuid())
  leadId         String
  agentId        String?
  channel        String   @default("EMAIL")
  subject        String?
  status         String   @default("OPEN") // OPEN, NEEDS_REVIEW, RESPONDED, CLOSED
  classification String   @default("UNCLASSIFIED") // INTERESTED, OBJECTION, SPAM, NOT_NOW
  summary        String?
  lastMessageAt  DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  lead     Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agent    SwarmAgent?   @relation(fields: [agentId], references: [id], onDelete: SetNull)
  messages InboxMessage[]
}

model InboxMessage {
  id               String   @id @default(uuid())
  threadId         String
  direction        String   // INBOUND, OUTBOUND
  senderName       String?
  senderEmail      String?
  body             String
  aiSuggestedReply String?
  status           String   @default("RECEIVED") // RECEIVED, DRAFTED, SENT
  createdAt        DateTime @default(now())

  thread InboxThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
}

model RevenueAttribution {
  id             String   @id @default(uuid())
  leadId         String
  agentId        String?
  amount         Int
  currency       String   @default("USD")
  campaignName   String?
  strategyLabel  String?
  touchpointCount Int     @default(1)
  note           String?
  closedAt       DateTime @default(now())
  createdAt      DateTime @default(now())

  lead  Lead       @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agent SwarmAgent? @relation(fields: [agentId], references: [id], onDelete: SetNull)
}

model FeedbackEntry {
  id           String   @id @default(uuid())
  leadId       String?
  agentId      String?
  draftId      String?
  createdById  String?
  feedbackType String   // APPROVED, REJECTED, EDITED, TRAINING, OVERRIDE
  sentiment    String   @default("NEUTRAL")
  score        Int?
  note         String
  createdAt    DateTime @default(now())

  lead      Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  agent     SwarmAgent?  @relation(fields: [agentId], references: [id], onDelete: SetNull)
  draft     OutreachDraft? @relation(fields: [draftId], references: [id], onDelete: SetNull)
  createdBy User?        @relation("FeedbackCreator", fields: [createdById], references: [id], onDelete: SetNull)
}

model RelationGraphNode {
  id                String   @id @default(uuid())
  entityType        String
  entityId          String
  label             String
  summary           String?
  semanticText      String?
  keywordFingerprint String?
  metadata          String?
  healthScore       Int?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  outgoingEdges RelationGraphEdge[] @relation("RelationGraphEdgeSource")
  incomingEdges RelationGraphEdge[] @relation("RelationGraphEdgeTarget")

  @@unique([entityType, entityId])
  @@index([entityType, entityId])
  @@index([entityType, updatedAt])
}

model RelationGraphEdge {
  id           String   @id @default(uuid())
  sourceNodeId String
  targetNodeId String
  relationType String
  rationale    String
  strength     Int      @default(50)
  confidence   Int      @default(50)
  semanticScore Int?
  discoveredBy String   @default("HEURISTIC")
  metadata     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sourceNode RelationGraphNode @relation("RelationGraphEdgeSource", fields: [sourceNodeId], references: [id], onDelete: Cascade)
  targetNode RelationGraphNode @relation("RelationGraphEdgeTarget", fields: [targetNodeId], references: [id], onDelete: Cascade)

  @@unique([sourceNodeId, targetNodeId, relationType])
  @@index([sourceNodeId, relationType])
  @@index([targetNodeId, relationType])
  @@index([relationType, strength])
}

model PipelineRun {
  id         String    @id @default(uuid())
  type       String
  status     String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  metadata   String?   // Store as JSON string since SQLite doesn't natively support JSON in Prisma sometimes, though Prisma supports it as String
  errorText  String?
  steps      PipelineRunStep[]
}

model PipelineRunStep {
  id            String    @id @default(uuid())
  pipelineRunId String
  stepName      String
  status        String
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  metadata      String?   // JSON string
  errorText     String?

  run PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(uuid())
  leadId    String?
  userId    String?
  type      String
  message   String
  metadata  String?  // JSON string
  createdAt DateTime @default(now())

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   // JSON string
  updatedAt DateTime @updatedAt
}

model ScrapedRecord {
  id            String    @id @default(uuid())
  sourceName    String
  sourceUrl     String
  title         String?
  authors       String?
  institution   String?
  abstractText  String?
  rawPayload    String?   // JSON string
  discoveredAt  DateTime  @default(now())
  pipelineRunId    String?
  processingStatus String   @default("PENDING") // PENDING, PROCESSED, REJECTED
}
