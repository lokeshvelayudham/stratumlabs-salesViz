// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(uuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  accounts      Account[]
  sessions      Session[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(uuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(uuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Lead {
  id           String     @id @default(uuid())
  firstName    String?
  lastName     String?
  fullName     String
  email        String?
  institution  String?
  role         String?
  department   String?
  labName      String?
  
  sourceType   String     @default("AUTO") // AUTO, MANUAL
  sourceName   String?
  sourceUrl    String?
  eventName    String?

  status       String     @default("NEW") // NEW, REVIEW, APPROVED, REJECTED, CONTACTED, REPLIED, INTERESTED, CLOSED
  tier         String     @default("UNRANKED") // TIER1, TIER2, TIER3, UNRANKED
  fitScore     Int?
  researchArea String?
  notes        String?
  whyRelevant  String?
  aiSummary    String?
  rawSourceText String?

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  tags             LeadTag[]
  scoreBreakdowns  LeadScoreBreakdown[]
  outreachDrafts   OutreachDraft[]
  activities       ActivityLog[]
}

model LeadTag {
  id     String @id @default(uuid())
  leadId String
  value  String

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadScoreBreakdown {
  id        String @id @default(uuid())
  leadId    String
  criterion String
  score     Int
  reason    String

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model OutreachDraft {
  id        String      @id @default(uuid())
  leadId    String
  subject   String
  body      String
  followup1 String?
  followup2 String?
  status    String      @default("PENDING_REVIEW") // PENDING_REVIEW, APPROVED, SENT, REJECTED, ARCHIVED
  aiModel   String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model PipelineRun {
  id         String    @id @default(uuid())
  type       String
  status     String
  startedAt  DateTime  @default(now())
  finishedAt DateTime?
  metadata   String?   // Store as JSON string since SQLite doesn't natively support JSON in Prisma sometimes, though Prisma supports it as String
  errorText  String?
  steps      PipelineRunStep[]
}

model PipelineRunStep {
  id            String    @id @default(uuid())
  pipelineRunId String
  stepName      String
  status        String
  startedAt     DateTime  @default(now())
  finishedAt    DateTime?
  metadata      String?   // JSON string
  errorText     String?

  run PipelineRun @relation(fields: [pipelineRunId], references: [id], onDelete: Cascade)
}

model ActivityLog {
  id        String   @id @default(uuid())
  leadId    String?
  userId    String?
  type      String
  message   String
  metadata  String?  // JSON string
  createdAt DateTime @default(now())

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)
}

model AppSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String   // JSON string
  updatedAt DateTime @updatedAt
}

model ScrapedRecord {
  id            String    @id @default(uuid())
  sourceName    String
  sourceUrl     String
  title         String?
  authors       String?
  institution   String?
  abstractText  String?
  rawPayload    String?   // JSON string
  discoveredAt  DateTime  @default(now())
  pipelineRunId    String?
  processingStatus String   @default("PENDING") // PENDING, PROCESSED, REJECTED
}
